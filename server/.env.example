PORT=4000

# MongoDB Atlas connection string. Get it from your Atlas cluster → "Connect" → "Drivers".
# Make sure to URL-encode any special characters in the password and include the db name.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/mingle?retryWrites=true&w=majority

# Per-user Google Calendar secret iCal URLs are stored in MongoDB after
# connect — nothing else is required here for calendar import.

# Google Gemini API key — powers the map's AI-generated hangout
# suggestions. Get a free key at https://aistudio.google.com/apikey
# (free tier covers our use case; otherwise gemini-3.1-flash-lite
# bills at $0.25/$1.50 per 1M input/output tokens). The route falls
# back to a local rules-based suggestion if this is missing or any
# call to Gemini fails, so the app stays functional without it.
GEMINI_API_KEY=
